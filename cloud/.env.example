# ─── LakeLogic Cloud — Environment Variables ─────────────────────────────────
#
# Copy this file to .env and fill in your values before running locally.
# In Cloud Run, set these via the Console or --set-env-vars flag.
#
# DO NOT commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Name of your Google Cloud Storage bucket (e.g. lakelogic-data)
GCS_BUCKET=lakelogic_bucket

# Your Squarespace site origin — only this domain can embed or call the app
ALLOWED_ORIGIN=https://www.vande.tech

# Port — Cloud Run injects this automatically (leave as 8080 for local Docker testing)
PORT=8080
